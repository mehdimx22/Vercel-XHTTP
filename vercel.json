{
  "version": 2,
  "name": "data-sync-provider",
  "rewrites": [
    {
      "source": "/service-worker/:path*",
      "destination": "/api/logic-module"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/api/logic-module"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex" },
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
